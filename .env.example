# --- Backend (.env) ---
PORT=3000
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key

# Neo4j Aura (Get these from your Aura dashboard)
NEO4J_URL=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password

# FAISS Service (Get this from your Railway FAISS service URL)
FAISS_URL=http://faiss-service.railway.internal:8001
